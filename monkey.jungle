project.manifest = manifest.xml

# Default resources (Edge 540/840: 246x322)
base.resourcePath = resources

# Edge 1040: 282x470, larger fonts
edge1040.resourcePath = resources-rectangle-282x470;resources/strings;resources/settings

# Edge 1050: 480x800, high-DPI fonts
edge1050.resourcePath = resources-rectangle-480x800;resources/strings;resources/settings
